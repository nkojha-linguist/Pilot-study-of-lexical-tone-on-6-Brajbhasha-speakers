# Timepoint-wise analysis for disyllables using dataset-wise imputed data
disyll_timepoint_results <- map(disyll_datasets, function(ds) {
  map_dfr(timepoints, function(tp) {
    model <- fit_lme(as.formula(paste(tp, "~ Tone + (1 | Subject) + (1 | Pair)")), ds)
    fe <- extract_fixef(model)
    map_dfr(1:nrow(fe), function(i) {
      data.frame(
        Dataset = paste0(unique(ds$Gender), "-", unique(ds$TBU_syll), "s", 
                         ifelse(unique(ds$Syllable) == "Syll1", "i", "ii")),
        Timepoint = tp,
        Term = rownames(fe)[i],
        Estimate = fe[i, 1],
        Std_Error = fe[i, 2],
        df = fe[i, 3],
        t_value = fe[i, 4],
        p_value = fe[i, 5],
        Signif = add_significance(fe[i, 5])
      )
    })
  })
})

# Print timepoint results
walk(names(disyll_timepoint_results), function(ds_name) {
  cat("\n", strrep("=", 60), "\n")
  cat("TIMEPOINT-WISE FIXED EFFECTS FOR DATASET:", ds_name, "\n")
