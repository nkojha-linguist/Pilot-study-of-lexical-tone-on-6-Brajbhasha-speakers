# Fit models for all nuanced datasets using the pre-created dataset-wise imputed datasets
fit_dataset_models <- function(datasets) {
  map(datasets, function(ds) {
    list(
      f0 = fit_lme(F0 ~ Tone + (1 | Subject) + (1 | Pair), ds),
      dur = fit_lme(Duration ~ Tone + (1 | Subject) + (1 | Pair), ds)
    )
  })
}

# Use the disyllabic datasets that were created with dataset-wise imputation
dataset_models <- fit_dataset_models(disyll_datasets)

# Create results tables
create_results_table <- function(models, dep_var) {
  map_dfr(names(models), function(ds_name) {
    fe <- extract_fixef(models[[ds_name]][[dep_var]])
    map_dfr(1:nrow(fe), function(i) {
      data.frame(
        Dataset = ds_name,
        Dependent_Variable = dep_var,
        Term = rownames(fe)[i],
        Estimate = fe[i, 1],
        Std_Error = fe[i, 2],
        df = fe[i, 3],
        t_value = fe[i, 4],
        p_value = fe[i, 5],
        Signif = add_significance(fe[i, 5])
      )
    })
  })
}

f0_results <- create_results_table(dataset_models, "f0")
dur_results <- create_results_table(dataset_models, "dur")

