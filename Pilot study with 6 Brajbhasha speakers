# Create disyllabic datasets
create_disyllabic_datasets <- function(data) {
  genders <- c("MALE", "FEMALE")
  tbu_locs <- c("TS1", "TS2")
  syllables <- c("Syll1", "Syll2")
  
  datasets <- list()
  for(gender in genders) {
    for(tbu in tbu_locs) {
      for(i in seq_along(syllables)) {
        syll <- syllables[i]
        ds_name <- paste0(gender, "-", tbu, "s", ifelse(i == 1, "i", "ii"))
        datasets[[ds_name]] <- data %>% 
          filter(WordType == "Disyllabic", Gender == gender, TBU_syll == tbu, Syllable == syll)
      }
    }
  }
  datasets
}

disyll_datasets <- create_disyllabic_datasets(data_clean)
disyll_data <- data_clean %>% filter(WordType == "Disyllabic")

