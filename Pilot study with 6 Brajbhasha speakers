# Pitch contour analysis by gender
analyze_contours <- function(gender_data, gender_name) {
  map_dfr(timepoints, function(tp) {
    model <- fit_lme(as.formula(paste(tp, "~ Tone + (1 | Subject) + (1 | Pair)")), gender_data)
    fe <- extract_fixef(model)
    
    map_dfr(1:nrow(fe), function(i) {
      data.frame(
        Timepoint = tp,
        Term = rownames(fe)[i],
        Estimate = fe[i, 1],
        Std_Error = fe[i, 2],
        df = fe[i, 3],
        t_value = fe[i, 4],
        p_value = fe[i, 5],
        Signif = add_significance(fe[i, 5])
      )
    })
  })
}

