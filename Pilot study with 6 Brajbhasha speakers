# Load required libraries
library(readxl); library(lme4); library(lmerTest); library(dplyr); library(tidyr); library(ggplot2); library(gridExtra); library(emmeans); library(broom.mixed); library(stringr)

# Read the data
data <- read_xlsx("Phase 1 OUTPUT (TONE).xlsx", sheet = "All")
data$Tone <- factor(data$Tone, levels = c("Neutral", "Low"))
# Data preprocessing - handle missing values using mean imputation
data_clean <- data %>%
  mutate(across(c(F0, Duration, p0, p1, p2, p3, p4, p5, p6, p7, p8, p9, p10), ~ifelse(is.na(.), mean(., na.rm = TRUE), .)))

# Factor releveling
data_clean$Tone <- relevel(factor(data_clean$Tone), ref = "Neutral")
data_clean$Gender <- factor(data_clean$Gender)
data_clean$Subject <- factor(data_clean$Subject)
data_clean$Pair <- factor(data_clean$Pair)
data_clean$TBU_syll <- factor(data_clean$TBU_syll)
data_clean$Syllable <- factor(data_clean$Syllable)
data_clean$WordType <- factor(data_clean$WordType)

# Separate monosyllabic and disyllabic data
monosyll_data <- data_clean %>% filter(WordType == "Monosyllabic")
disyll_data <- data_clean %>% filter(WordType == "Disyllabic")

