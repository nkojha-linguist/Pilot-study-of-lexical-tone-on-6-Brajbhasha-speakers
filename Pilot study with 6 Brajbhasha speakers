fixef_mono_female <- extract_fixef(lme_mono_f0_female)


# FIGURES 2-3: Boxplots
create_boxplot <- function(data, x_var, y_var, facet_var, title) {
  ggplot(data, aes(x = .data[[x_var]], y = .data[[y_var]], fill = .data[[x_var]])) +
    geom_boxplot() +
    {if(facet_var != "1") facet_wrap(as.formula(paste("~", facet_var)), scales = "free")} +
    labs(title = title, y = y_var, x = x_var) +
    theme_minimal() +
    theme(
      strip.placement = "outside", 
      axis.text.x = element_text(angle = 45, hjust = 1), 
      panel.background = element_rect(fill = "grey90", color = NA), 
      panel.grid.major = element_line(color = "grey80"), 
      panel.grid.minor = element_line(color = "grey85"), 
      strip.background = element_rect(fill = "grey80")
    )
}

