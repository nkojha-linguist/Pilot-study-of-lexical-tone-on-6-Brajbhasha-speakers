# Function to add significance stars
add_significance <- function(p_value) {
  cut(p_value, breaks = c(-Inf, 0.001, 0.01, 0.05, 0.1, Inf), labels = c("***", "**", "*", ".", ""),  right = FALSE)}

# DATASET-WISE MEAN IMPUTATION FUNCTION
impute_dataset_means <- function(data) {
  data %>%
    group_by(Dataset) %>%
    mutate(across(c(F0, Duration, p0:p10), ~{
      if(any(is.na(.))) {
        ifelse(is.na(.), mean(., na.rm = TRUE), .)
      } else {
        .
      }
    })) %>%
    ungroup()
}

# Data preprocessing with dataset-wise imputation
data_clean <- data %>%
  mutate(across(c(Tone, Gender, Subject, Pair, TBU_syll, Syllable, WordType, Dataset), factor),
         Tone = relevel(factor(Tone, levels = c("Neutral", "Low")), ref = "Neutral")) %>%
  impute_dataset_means()

# Create monosyllabic datasets
monosyll_datasets <- list(
  "Mono-M" = data_clean %>% filter(WordType == "Monosyllabic", Gender == "MALE"),
  "Mono-F" = data_clean %>% filter(WordType == "Monosyllabic", Gender == "FEMALE")
)

# Combine for overall monosyllabic analysis (using dataset-wise imputed data)
