# LME model for overall F0 contrast
lme_mono_f0 <- lmer(F0 ~ Tone + (1 + Tone | Subject) + (1 + Tone | Pair), data = monosyll_data)
summary(lme_mono_f0)
# Likelihood Ratio Test for overall model
lme_mono_f0_null <- lmer(F0 ~ 1 + (1 + Tone | Subject) + (1 + Tone | Pair), data = monosyll_data)
anova(lme_mono_f0_null, lme_mono_f0)

# Gender-wise LME models for F0
lme_mono_f0_male <- lmer(F0 ~ Tone + (1 + Tone | Subject) + (1 + Tone | Pair), data = monosyll_data %>% filter(Gender == "MALE"))
lme_mono_f0_male_null <- lmer(F0 ~ 1 + (1 + Tone | Subject) + (1 + Tone | Pair), data = monosyll_data %>% filter(Gender == "MALE"))
summary(lme_mono_f0_male)
anova(lme_mono_f0_male, lme_mono_f0_male_null)
lme_mono_f0_female <- lmer(F0 ~ Tone + (1 + Tone | Subject) + (1 + Tone | Pair), data = monosyll_data %>% filter(Gender == "FEMALE"))
lme_mono_f0_female_null <- lmer(F0 ~ Tone + (1 + Tone | Subject) + (1 + Tone | Pair), data = monosyll_data %>% filter(Gender == "FEMALE"))
summary(lme_mono_f0_female)
anova(lme_mono_f0_female, lme_mono_f0_female_null)

