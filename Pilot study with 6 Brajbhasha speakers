# Timepoints for contour analysis
timepoints <- paste0("p", 0:10)
# Create a list to store all timepoint-wise results for each dataset
disyll_timepoint_results <- list()
# Loop through each dataset and run timepoint-wise LME models
for(ds_name in names(datasets)) {
  # Initialize data frame for this dataset
  dataset_timepoint_table <- data.frame()
  # Run LME models for each timepoint
  for(tp in timepoints) {
    formula <- as.formula(paste(tp, "~ Tone + (1 + Tone | Subject) + (1 + Tone | Pair)"))
    # Fit the model
    lme_model <- lmer(formula, data = datasets[[ds_name]])
    # Extract fixed effects
    model_summary <- summary(lme_model)
    fixed_effects <- model_summary$coefficients
    # Add to the dataset table
    for(i in 1:nrow(fixed_effects)) {
      dataset_timepoint_table <- rbind(dataset_timepoint_table, data.frame(Dataset = ds_name, Timepoint = tp, Term = rownames(fixed_effects)[i], Estimate = fixed_effects[i, 1], Std_Error = fixed_effects[i, 2], df = fixed_effects[i, 3], t_value = fixed_effects[i, 4], p_value = fixed_effects[i, 5], Signif = add_significance(fixed_effects[i, 5])))}}
  
  # Store the results for this dataset
  disyll_timepoint_results[[ds_name]] <- dataset_timepoint_table
  # Display the table for this dataset - CORRECTED STRING CONCATENATION
  cat("\n")
  cat(strrep("=", 60), "\n")
  cat("TIMEPOINT-WISE FIXED EFFECTS FOR DATASET:", ds_name, "\n")
  cat(strrep("=", 60), "\n")
  print(dataset_timepoint_table, row.names = FALSE)
  cat("\nSignificance codes: *** p < 0.001, ** p < 0.01, * p < 0.05, . p < 0.1\n")
}



